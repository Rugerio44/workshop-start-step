---
import type { MiniBio } from '../mini-bio.model';
import ShapeOval from '#assets/shapes/oval.svg';
import ShapeRectangle from '#assets/shapes/rectangle.svg';
import ContactButtons from '#components/contact-buttons.astro';

interface Props {
  content: MiniBio;
}

const { content } = Astro.props;
---



<section
  class="bg-primary-50 dark:bg-primary-100 relative hidden overflow-clip rounded-2xl p-6 lg:block"
  aria-labelledby="about-me-aside-heading"
>
  <div>
    <h2 id="about-me-aside-heading" class="text-2xl font-bold text-primary-900 dark:text-primary-100 margin-bottom-6">
      {content.title}
    </h2>
  </div>
  <div class="flex flex-col items-center justify-center text-center gap-2 margin-top-6 ">
    <div class="h-24 w-24 ">
      <img 
        src={content.image.url}
        alt={content.imageAlt}
        class="block h-full w-full rounded-full object-cover"
        height="80"
        width="80"
        >
    </div>

    <span class="text-sm font-medium text-primary-700 dark:text-primary-300">{content.name}</span>
    <span class="text-sm text-primary-500 dark:text-primary-400">{content.role}</span>
    <p class="text-sm text-primary-600 dark:text-primary-400">{content.description}</p>
    <ContactButtons class="margin-top-4" />
  </div>
  <!-- Decorative shapes -->
  <div class="text-primary-500/25 absolute top-[-48%] left-[-30%] h-[243px] w-[420px]" aria-hidden="true">
    <ShapeRectangle />
  </div>
  <div class="text-primary-500/25 absolute top-[91.5%] left-[-8%] h-[243px] w-[420px] overflow-clip" aria-hidden="true">
    <ShapeOval />
  </div>
</section>
