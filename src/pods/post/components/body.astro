---
import HeartIcon from '#assets/icons/heart.svg';
import type { Post } from '#pods/post-collection/post-collection.model.ts';
import MarkdownRenderer from '#components/markdown-renderer.astro';


interface Props {
  entry: Post;
  lickeCount?: number;
  minRead?: string;
}

const { entry, lickeCount, minRead } = Astro.props;
---

<div class="flex flex-col gap-6">
  <h1 class="text-4xl font-bold">{entry.title}</h1>
  <div class="border-tbase-500/90 mb-2 flex items-center justify-between gap-4">
    <p>{entry.readTime} {minRead}</p>
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="bg-base-100/90 hover:bg-base-100 flex items-center gap-1 rounded-full px-3 py-1 text-sm"
      >
        <HeartIcon class="w-4" />
      </button>
      <span>{lickeCount}</span>
    </div>
  </div>
  <MarkdownRenderer content={entry.content} />
</div>
