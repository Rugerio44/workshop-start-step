---
import type { Post } from '#pods/post-collection/post-collection.model.ts';
import Header from '#pods/post/components/header.astro';


interface Props {
  postEntry: Post;
}

const { postEntry } = Astro.props;

const likeCount = 6;

const postContent = {
    backButton: 'Atras',
    published: 'Publicado el',
    minRead: 'min read',
};
---



<section>
    <Header
      gobackTexyt={postContent.backButton}
      publishedText={postContent.published}
      date={postEntry.date}
    />
    <div>
        {postEntry.title}
        <time datetime={postEntry.date}>
            {postContent.published} {new Date(postEntry.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
    </div>
</section>

  
